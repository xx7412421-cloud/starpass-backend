generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  stellarAddress String    @unique @map("stellar_address")
  role           UserRole  @default(FAN)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  creator        Creator?
  fan            Fan?
  sessions       Session[]
  @@map("users")
}

enum UserRole {
  CREATOR
  FAN
  ADMIN
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model Creator {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  stellarAddress String   @unique @map("stellar_address")
  displayName    String   @map("display_name")
  bio            String?
  avatarUrl      String?  @map("avatar_url")
  totalEarned    Decimal  @default(0) @map("total_earned")
  registeredAt   DateTime @map("registered_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tiers          Tier[]
  passes         Pass[]
  webhooks       WebhookConfig[]
  @@map("creators")
}

model WebhookConfig {
  id        String   @id @default(uuid())
  creatorId String   @map("creator_id")
  url       String
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  @@map("webhook_configs")
}

model Fan {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  stellarAddress String   @unique @map("stellar_address")
  displayName    String?  @map("display_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passes         Pass[]
  @@map("fans")
}

model Tier {
  id           String   @id @default(uuid())
  onChainId    Int      @map("on_chain_id")
  creatorId    String   @map("creator_id")
  name         String
  priceUsdc    Decimal  @map("price_usdc")
  durationDays Int      @map("duration_days")
  maxSupply    Int      @default(0) @map("max_supply")
  minted       Int      @default(0)
  active       Boolean  @default(true)
  syncedAt     DateTime @map("synced_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  creator      Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  passes       Pass[]
  @@unique([creatorId, onChainId])
  @@map("tiers")
}

model Pass {
  id          String   @id @default(uuid())
  onChainId   BigInt   @unique @map("on_chain_id")
  tierId      String   @map("tier_id")
  creatorId   String   @map("creator_id")
  fanId       String   @map("fan_id")
  purchasedAt DateTime @map("purchased_at")
  expiresAt   DateTime @map("expires_at")
  active      Boolean  @default(true)
  syncedAt    DateTime @map("synced_at")
  createdAt   DateTime @default(now()) @map("created_at")
  tier        Tier     @relation(fields: [tierId], references: [id])
  creator     Creator  @relation(fields: [creatorId], references: [id])
  fan         Fan      @relation(fields: [fanId], references: [id])
  @@map("passes")
}

model IndexerCheckpoint {
  id         String   @id @default("singleton")
  lastLedger Int      @default(0) @map("last_ledger")
  updatedAt  DateTime @updatedAt @map("updated_at")
  @@map("indexer_checkpoints")
}
